#!/usr/bin/env bash
set -euo pipefail

export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=parrlax-hypr-drift
export XDG_CURRENT_DESKTOP=driftwm
export XDG_DESKTOP_SESSION=parrlax-hypr-drift
export VOLTA_HOME="$HOME/.volta"
export NVM_DIR="$HOME/.nvm"
export PATH="$HOME/.local/bin:$HOME/.nvm/versions/node/v18.20.8/bin:$HOME/.volta/bin:$HOME/.pyenv/bin:$PATH"
export MOZ_ENABLE_WAYLAND=1
export QT_QPA_PLATFORM=wayland
export SDL_VIDEODRIVER=wayland
export GDK_BACKEND=wayland,x11
export ELECTRON_OZONE_PLATFORM_HINT=wayland
export NIXOS_OZONE_WL=1

unset DISPLAY || true
unset WAYLAND_DISPLAY || true

systemctl --user reset-failed driftwm.service 2>/dev/null || true
systemctl --user import-environment \
  PATH HOME USER LOGNAME SHELL XDG_RUNTIME_DIR XDG_SESSION_TYPE \
  XDG_SESSION_DESKTOP XDG_CURRENT_DESKTOP XDG_DESKTOP_SESSION VOLTA_HOME NVM_DIR \
  MOZ_ENABLE_WAYLAND QT_QPA_PLATFORM SDL_VIDEODRIVER GDK_BACKEND \
  ELECTRON_OZONE_PLATFORM_HINT NIXOS_OZONE_WL 2>/dev/null || true
dbus-update-activation-environment --systemd \
  PATH HOME USER LOGNAME SHELL XDG_RUNTIME_DIR XDG_SESSION_TYPE \
  XDG_SESSION_DESKTOP XDG_CURRENT_DESKTOP XDG_DESKTOP_SESSION VOLTA_HOME NVM_DIR \
  MOZ_ENABLE_WAYLAND QT_QPA_PLATFORM SDL_VIDEODRIVER GDK_BACKEND \
  ELECTRON_OZONE_PLATFORM_HINT NIXOS_OZONE_WL 2>/dev/null || true

CONFIG="/home/unknown/Documents/scripts/projectcampaign/parrlax-hypr-drift/config.toml"
DRIFTWM_BIN="/home/unknown/Documents/scripts/projectcampaign/driftwm-src/target/release/driftwm"

if [[ ! -x "$DRIFTWM_BIN" ]]; then
    DRIFTWM_BIN="/home/unknown/Documents/scripts/projectcampaign/driftwm-src/target/debug/driftwm"
fi

exec dbus-run-session env -u DISPLAY -u WAYLAND_DISPLAY "$DRIFTWM_BIN" --backend udev --config "$CONFIG"
